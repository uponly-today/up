# Xiaomi MiMo (the "brain") — OpenAI-compatible API
# Get a key at https://platform.xiaomimimo.com/
MIMO_API_KEY=
# Base URL for the MiMo OpenAI-compatible endpoint (adjust to the platform's docs if different)
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
# Model to use: mimo-v2.5-pro | mimo-v2.5
MIMO_MODEL=mimo-v2.5-pro

# Blockscout (Base chain on-chain data) — public, no key required
BLOCKSCOUT_BASE_URL=https://base.blockscout.com

# Public X (Twitter) handle shown on the site
NEXT_PUBLIC_X_HANDLE=uponly
